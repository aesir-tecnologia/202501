    "eslint": "^9.36.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "nuxt": "^4.1.2",
    "typescript": "^5.9.2",
    "vue": "^3.5.21",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.68",
